# Resend API key — get from resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# From address (must be verified in Resend)
FROM_EMAIL=secondary.edu@eduversal.org
FROM_NAME=Eduversal Education

# Secret token — CentralHub sends this in Authorization header
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
API_SECRET=your_random_secret_here

# Firebase service account JSON (base64-encoded for Railway env vars)
# Encode with: node -e "console.log(Buffer.from(require('fs').readFileSync('serviceAccount.json')).toString('base64'))"
FIREBASE_SERVICE_ACCOUNT_BASE64=

# Firebase project ID
FIREBASE_PROJECT_ID=centralhub-8727b

# Port (Railway sets this automatically)
PORT=3000
